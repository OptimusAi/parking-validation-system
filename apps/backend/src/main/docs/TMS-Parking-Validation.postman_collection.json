    {
      "name": "✅ Validations",
      "description": "**Status lifecycle:** `ACTIVE` → `EXTENDED` → `EXPIRED` (scheduler) | `CANCELLED`\n\n**Duplicate guard (new):** Creating a session for a plate with existing `ACTIVE`/`EXTENDED` session → `422 ALREADY_VALIDATED`.\n\n**Extend guard (fixed):** Total time from `startTime` must not exceed `zone.maxDurationMinutes` → `422 LINK_EXPIRED`.",
      "item": [
        {
          "name": "List Validations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/validations?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","validations"],
              "query": [
                { "key": "page",         "value": "0" },
                { "key": "size",         "value": "20" },
                { "key": "status",       "value": "ACTIVE",               "disabled": true },
                { "key": "zoneId",       "value": "{{zoneId}}",           "disabled": true },
                { "key": "licensePlate", "value": "ABC123",               "disabled": true },
                { "key": "from",         "value": "2026-05-01T00:00:00Z", "disabled": true },
                { "key": "to",           "value": "2026-05-31T23:59:59Z", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Validation",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/validations/{{validationId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","validations","{{validationId}}"] } }
        },
        {
          "name": "Create Validation (Staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 422) {",
                  "    const res = pm.response.json();",
                  "    console.warn('422:', res.code, '-', res.message);",
                  "    return;",
                  "}",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "if (res.id) pm.collectionVariables.set('validationId', res.id);",
                  "console.log('Session created:', res.id, '| plate:', res.licensePlate, '| status:', res.status);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"zoneId\":          \"{{zoneId}}\",\n  \"licensePlate\":    \"ABC123\",\n  \"durationMinutes\": 60,\n  \"endUserEmail\":    \"driver@example.com\",\n  \"endUserPhone\":    null\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/v1/validations", "host": ["{{baseUrl}}"], "path": ["api","v1","validations"] },
            "description": "**Duplicate guard:** `422 ALREADY_VALIDATED` if plate already has ACTIVE/EXTENDED session.\n\n**Quota check:** `422 QUOTA_EXCEEDED` if tenant limit reached.\n\n**durationMinutes** capped at `zone.maxDurationMinutes`."
          }
        },
        {
          "name": "Create Validation via QR Token (Public — no auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 422) { console.warn('422:', pm.response.json().code); return; }",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "if (res.id) pm.collectionVariables.set('validationId', res.id);",
                  "console.log('Public session:', res.id, '| plate:', res.licensePlate);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"licensePlate\": \"ABC123\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/v1/validations/public/{{linkToken}}", "host": ["{{baseUrl}}"], "path": ["api","v1","validations","public","{{linkToken}}"] },
            "description": "No auth — HMAC token provides context.\n\n**422 codes:** `ALREADY_VALIDATED`, `LINK_EXPIRED`, `QUOTA_EXCEEDED`\n\n**401:** `INVALID_TOKEN` (tampered/malformed token)"
          }
        },
        {
          "name": "Extend Validation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 422) { console.warn('Cannot extend:', pm.response.json().message); return; }",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Status is EXTENDED', () => pm.expect(res.status).to.equal('EXTENDED'));",
                  "console.log('Extended to:', res.endTime);"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"extraMinutes\": 30\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/v1/validations/{{validationId}}/extend", "host": ["{{baseUrl}}"], "path": ["api","v1","validations","{{validationId}}","extend"] },
            "description": "**Max duration guard:** `(endTime + extraMinutes) - startTime` must not exceed `zone.maxDurationMinutes`. Returns `422 LINK_EXPIRED` otherwise."
          }
        },
        {
          "name": "Cancel Validation",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));","pm.test('CANCELLED', () => pm.expect(pm.response.json().status).to.equal('CANCELLED'));"] } }],
