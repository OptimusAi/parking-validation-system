          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));","pm.test('code is INVALID_TOKEN', () => pm.expect(pm.response.json().code).to.equal('INVALID_TOKEN'));"] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/validations", "host": ["{{baseUrl}}"], "path": ["api","v1","validations"] },
            "description": "No Authorization header. Expect `401 INVALID_TOKEN`."
          }
        }
      ]
    }
  ]
}
